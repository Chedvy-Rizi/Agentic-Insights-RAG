*.py[cod]
*$py.class

# IDE Settings (הגדרות אישיות של VS Code)
.vscode/

# UI Temporary Files (תיקיות של Gradio)
.gradio/

# System Files
.DS_Store
Thumbs.db

# Optional: Large Data Files (אם את לא רוצה להעלות את ה-JSON)
# structured_data.json