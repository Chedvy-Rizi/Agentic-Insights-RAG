# סביבה וירטואלית (לא מעלים את כל התיקייה של ה-venv)
venv/
.env

# קבצי הגדרות של פייתון
__pycache__/
*.py[cod]
*$py.class

# קבצי מפתחות ואבטחה (קריטי!)
.env
keys.txt
*.pem
*.key

